{
  "name": "doll-wardrobe",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:workers": "wrangler dev",
    "build": "next build",
    "build:workers": "wrangler deploy --dry-run",
    "start": "next start",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.workers.json && tsc --noEmit -p tsconfig.sw.json",
    "lint": "oxlint src/ workers/ && eslint .",
    "format": "oxfmt --write 'src/**/*.{ts,tsx}' 'workers/**/*.ts' 'src/**/*.css' && prettier --write '**/*.{json,md}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:workers": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply doll-wardrobe-db",
    "db:migrate:local": "wrangler d1 migrations apply doll-wardrobe-db --local"
  },
  "dependencies": {
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "jotai": "^2.12.3",
    "jotai-trpc": "^0.7.0",
    "@trpc/server": "^11.1.0",
    "@trpc/client": "^11.1.0",
    "@hono/trpc-server": "^0.4.2",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "jsqr": "^1.4.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@serwist/next": "^9.0.13",
    "serwist": "^9.0.13",
    "hono": "^4.7.7",
    "better-auth": "^1.2.8"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "tsc-files": "^1.1.4",
    "tailwindcss": "^4.1.4",
    "@tailwindcss/postcss": "^4.1.4",
    "postcss": "^8.5.3",
    "oxlint": "^1.1.0",
    "oxfmt": "^0.40.0",
    "eslint": "^9.25.0",
    "@eslint/js": "^9.25.0",
    "typescript-eslint": "^8.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-functional": "^9.0.4",
    "eslint-config-love": "^151.0.0",
    "prettier": "^3.5.3",
    "vitest": "^3.1.2",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "happy-dom": "^17.4.6",
    "msw": "^2.8.4",
    "wrangler": "^4.14.2",
    "@cloudflare/workers-types": "^4.20250410.0",
    "@opennextjs/cloudflare": "^1.3.1"
  }
}
