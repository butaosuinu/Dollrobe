{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@shared/lib/*": ["./src/lib/*"],
      "@shared/*": ["./src/types/*"]
    },
    "allowJs": true,
    "incremental": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "workers/src/trpc/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/app/sw.ts",
    "workers/**/*.test.ts",
    "workers/test/**"
  ]
}
