{
  "extends": "./tsconfig.workers.json",
  "compilerOptions": {
    "types": [
      "@cloudflare/workers-types",
      "node",
      "vitest/globals",
      "@cloudflare/vitest-pool-workers"
    ],
    "noUncheckedIndexedAccess": false,
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "workers/**/*.ts",
    "src/types/**/*.ts",
    "src/lib/confidence.ts",
    "src/lib/constants.ts"
  ],
  "exclude": ["node_modules"]
}
