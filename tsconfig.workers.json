{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "types": [
      "@cloudflare/workers-types",
      "vitest/globals",
      "@cloudflare/vitest-pool-workers"
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@shared/lib/*": ["./src/lib/*"],
      "@shared/*": ["./src/types/*"]
    }
  },
  "include": [
    "workers/**/*.ts",
    "src/types/**/*.ts",
    "src/lib/confidence.ts",
    "src/lib/constants.ts"
  ],
  "exclude": ["node_modules", "workers/**/*.test.ts", "workers/test/**"]
}
